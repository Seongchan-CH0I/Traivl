generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  name          String?
  profileImage  String?
  dnaType       String? // 예: "모험가", "본투비 푸드파이터"
  destinationId String? // 예: "KR_JEJU"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
