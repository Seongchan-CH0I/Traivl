generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}
model Place {
  id          Int      @id @default(autoincrement())
  name        String
  description String

  embedding   Unsupported("vector(1536)")?

  createdAt   DateTime @default(now())
}


